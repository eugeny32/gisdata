# Скопируйте этот файл в .env и заполните реальными данными хостинга/сервера.
# .env не коммитится в git (см. .gitignore).

PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_DATABASE=gisdata
PGSQL_USER=postgres
PGSQL_PASSWORD=

# Путь не меняем — путь к исходной базе South Net Reference Station
MDB_PATH=C:\Program Files (x86)\South Net Reference Station\SBR\E_SERVER64_230822\E_Ser190905.mdb
MDB_DRIVER=Microsoft Access Driver (*.mdb, *.accdb)

# Нужны только если на хостинге нет CLI и скрипты bin/*.php запускаются через
# браузер/веб-крон (см. README). Придумайте длинные случайные значения.
SETUP_TOKEN=
CRON_TOKEN=

# Earthdata Login (urs.earthdata.nasa.gov, регистрация бесплатная) — для
# автозагрузки эфемерид с CDDIS (NASA) в rinex_generate.php.
CDDIS_EARTHDATA_USER=
CDDIS_EARTHDATA_PASSWORD=

# FTP-выгрузка проекта на хостинг (bin/deploy_ftp.ps1).
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=

# Удалённый FTP с почасовыми RINEX-файлами станций (rinex.php — поиск и
# скачивание архивом).
GNSS_FTP_HOST=gnss.host
GNSS_FTP_USER=
GNSS_FTP_PASSWORD=
